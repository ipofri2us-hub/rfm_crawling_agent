# 이 파일을 복사해서 .env로 저장하세요.
# cp .env.example .env

# LLM_PROVIDER: mock(API 키 불필요) / ollama(로컬, 기본값) / qwen(회사 엔드포인트) / cloud(Anthropic API)
LLM_PROVIDER=ollama

# LLM_PROVIDER=ollama일 때 사용됩니다. 먼저 `ollama pull <모델명>`으로 모델을 받아두세요.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5

# LLM_PROVIDER=qwen일 때 사용됩니다. (회사에서 받을 예정인 엔드포인트/키 — 아직 비어있으면 qwen 사용 시 에러)
QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_MODEL=qwen3.5-72b-instruct

# LLM_PROVIDER=cloud일 때만 필요합니다.
ANTHROPIC_API_KEY=

# (선택) GitHub API rate limit 완화를 위한 Personal Access Token
GITHUB_TOKEN=

# (선택) 리포트를 Slack으로 전송하려면 Incoming Webhook URL을 입력하세요.
SLACK_WEBHOOK_URL=
