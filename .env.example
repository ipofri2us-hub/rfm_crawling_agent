# 이 파일을 복사해서 .env로 저장하세요.
# cp .env.example .env

# LLM_PROVIDER: mock(기본, API 키 불필요) 또는 cloud(Anthropic API 사용)
LLM_PROVIDER=mock

# LLM_PROVIDER=cloud일 때만 필요합니다.
ANTHROPIC_API_KEY=

# (선택) GitHub API rate limit 완화를 위한 Personal Access Token
GITHUB_TOKEN=

# (선택) 리포트를 Slack으로 전송하려면 Incoming Webhook URL을 입력하세요.
SLACK_WEBHOOK_URL=
